# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/
/build
dist/

# production
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
