logs
*.log

# env files (NEVER commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/*
